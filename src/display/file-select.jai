File_Utilities :: #import "File_Utilities";
POSIX :: #import "POSIX";
Sort :: #import "Sort";
String :: #import "String";

// @fixme Abstract all that in Chamber.
_starting_path :: () -> string {
    // Show home if possible.
    // @fixme Windows is getenv("HOMEDRIVE")/getenv("HOMEPATH");
    path := POSIX.getenv("HOME");
    if path == null {
        path = "/";
    }

    return Basic.to_string(path);
}

